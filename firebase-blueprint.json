{
  "entities": {
    "user": {
      "title": "User",
      "description": "A user of the Reven platform",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "The user's corporate email" },
        "name": { "type": "string", "description": "The user's first name" },
        "lastName": { "type": "string", "description": "The user's last name" },
        "cuil": { "type": "string", "description": "The user's CUIL/CUIT" },
        "phone": { "type": "string", "description": "The user's phone number" },
        "company": { "type": "string", "description": "The user's dealership name" },
        "plan": { "type": "string", "enum": ["plata", "oro", "platinum"], "description": "The user's membership plan" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "The admission status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user record was created" }
      },
      "required": ["uid", "email", "role", "status"]
    },
    "vehicle": {
      "title": "Vehicle",
      "description": "A vehicle listing in the marketplace",
      "type": "object",
      "properties": {
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "version": { "type": "string" },
        "year": { "type": "number" },
        "price": { "type": "number" },
        "photo": { "type": "string", "format": "uri" },
        "sellerUid": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "isWholesale": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["brand", "model", "year", "price", "sellerUid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "User profiles and admission data"
    },
    "/vehicles/{vehicleId}": {
      "schema": "vehicle",
      "description": "Vehicle listings"
    }
  }
}
